// 1. CẤU HÌNH KẾT NỐI (SỬA LẠI ĐÂY)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql" // Đổi từ sqlite sang mysql để khớp với Railway
  url      = env("DATABASE_URL")
}

// 2. BẢNG NGƯỜI DÙNG (USER)
model User {
  id         String   @id
  balance    Int      @default(1000)
  msgCount   Int      @default(0)
  totalWins  Int      @default(0)
  lastDaily  DateTime?
  createdAt  DateTime @default(now())
  
  houses     House[]

  @@index([id])
}

// 3. BẢNG BẤT ĐỘNG SẢN (HOUSE)
model House {
  id           String   @id @default(uuid())
  ownerId      String
  channelId    String   @unique
  name         String
  rarity       String
  multiplier   Float    @default(1.0)
  currentValue Int      @default(50000)
  level        Int      @default(1)
  
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([channelId])
}

// 4. BẢNG THỊ TRƯỜNG CHỨNG KHOÁN (MARKET)
model Market {
  id        Int      @id @default(1)
  price     Float    @default(100.0)
  history   String   @default("[]") // Lưu mảng giá JSON
  updatedAt DateTime @updatedAt
}
