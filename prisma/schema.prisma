generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Hoặc postgresql tùy bạn dùng
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id
  balance    Int      @default(100000)
  totalWins  Int      @default(0)  // Thống kê thắng đua ngựa
  createdAt  DateTime @default(now())
  
  // Quan hệ 1-n: Một người có thể có nhiều nhà (tối đa 10)
  houses     House[]

  @@index([id])
}

model House {
  id           String   @id @default(uuid())
  ownerId      String
  channelId    String   @unique // Dùng để tìm nhà khi người dùng vào Voice
  name         String
  rarity       String
  multiplier   Float    @default(1.0)
  currentValue Int      @default(50000)
  level        Int      @default(1)
  
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([channelId])
}
