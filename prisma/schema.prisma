datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String    @id // Discord User ID (Cố định)
  balance         Float     @default(1000) // Số tiền khởi tạo cho người mới
  level           Int       @default(1)    // Cấp độ Bất động sản (Dùng cho bot_realestate)
  
  // --- HỆ THỐNG NHIỆM VỤ HÀNG NGÀY (Daily Tasks) ---
  lastDaily       DateTime? @default(dbgenerated("'1970-01-01 00:00:00'"))
  msgCount        Int       @default(0)       // Đếm tin nhắn (Dùng cho nhiệm vụ Chatter)
  claimedChatter  Boolean   @default(false)   // Trạng thái đã nhận thưởng chat
  hasWonToday     Boolean   @default(false)   // Đã thắng Reaction/Race hôm nay chưa
  claimedWin      Boolean   @default(false)   // Trạng thái đã nhận thưởng thắng game

  // --- HỆ THỐNG KINH TẾ & TÀI SẢN ---
  // Lưu trữ dưới dạng Json để linh hoạt (Ví dụ: { "AAPL": 10, "SERVER": 5 })
  stocks          Json?     @default("{}")
  // Lưu trữ danh sách BĐS (Ví dụ: { "Biệt thự": 1, "Penthouse": 2 })
  properties      Json?     @default("{}")
  
  // --- CHỈ SỐ PHỤ ---
  lastReaction    DateTime? // Thời điểm chơi reaction gần nhất (để tránh spam)
  totalWins       Int       @default(0)       // Tổng số trận thắng lịch sử
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Market {
  id        Int      @id @default(1)
  // Lưu trữ giá cổ phiếu hiện tại (Ví dụ: { "VCASH": 150.5, "GOLD": 2000 })
  stocks    Json     
  updatedAt DateTime @updatedAt
}

model BlackMarket {
  id          Int      @id @default(1)
  // Danh sách vật phẩm hiếm đang bán trong ngày
  items       Json     
  nextRefresh DateTime // Thời gian chợ đen sẽ đổi món đồ mới
}
